# Supabase 프로젝트 설정 — 실제 값은 .env.local 에 넣으세요 (git에 커밋하지 않음)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 회계기준 RAG 적재 스크립트(scripts/standards/*)용 — 브라우저 앱에는 노출되지 않음(VITE_ 접두사 없음)
SUPABASE_SECRET_KEY=YOUR-SUPABASE-SECRET-KEY   # service_role 키. 적재 시 RLS 우회용. 절대 클라이언트에 넣지 말 것.
OPENAI_API_KEY=sk-...                          # 임베딩(text-embedding-3-small) 생성용
